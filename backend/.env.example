# ───────────── Required en producción ─────────────
NODE_ENV=production
PORT=3001                          # Railway/Render lo inyectan automáticamente

# Postgres — Railway/Render/Neon te lo dan
DATABASE_URL=postgresql://user:pass@host:5432/clubify

# Redis (opcional por ahora — sin uso hasta que activemos BullMQ workers)
REDIS_URL=redis://host:6379

# JWT secrets — generá con: openssl rand -base64 48
JWT_SECRET=__generar_con_openssl_rand_base64_48__
JWT_REFRESH_SECRET=__generar_con_openssl_rand_base64_48__
JWT_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# QR signing (HMAC) — generá con: openssl rand -base64 32
QR_HMAC_SECRET=__generar_con_openssl_rand_base64_32__

# URLs públicas (CORS, wa.me deeplinks, redirects de pago, webhook URLs)
APP_URL=https://soyclubify.com
API_URL=https://api.soyclubify.com

# ───────────── Object storage (S3-compatible) ─────────────
# Recomendado: Cloudflare R2 — gratis hasta 10GB, sin egress fees
#   https://dash.cloudflare.com/?to=/:account/r2
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_BUCKET=clubify-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_FORCE_PATH_STYLE=true

# ───────────── Apple Wallet (opcional) ─────────────
APPLE_PASS_TYPE_ID=pass.com.soyclubify.loyalty
APPLE_TEAM_ID=
APPLE_PASS_CERT_PATH=./certs/pass.pem
APPLE_PASS_CERT_PASSWORD=
APPLE_WWDR_PATH=./certs/wwdr.pem
APNS_KEY_PATH=./certs/apns.p8
APNS_KEY_ID=
APNS_TEAM_ID=

# ───────────── Google Wallet (opcional) ─────────────
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SA_JSON=./certs/google-wallet-sa.json

# ───────────── SMTP (opcional, para emails transaccionales) ─────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Clubify <noreply@soyclubify.com>

# ───────────── Pagos online (opcional, ver PENDIENTES.md §11) ─────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...
# WOMPI_PUBLIC_KEY=pub_prod_...
# WOMPI_PRIVATE_KEY=prv_prod_...
